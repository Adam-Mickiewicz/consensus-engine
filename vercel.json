{
  "functions": {
    "app/api/sock-brief/route.js": {
      "maxDuration": 30
    },
    "app/api/cron/sync-orders/route.js": {
      "maxDuration": 800
    },
    "app/api/cron/process-video-jobs/route.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-orders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/recalculate-crm",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/process-video-jobs",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/segment-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/recalculate-scores",
      "schedule": "30 10 * * *"
    }
  ]
}
